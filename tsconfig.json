{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "noEmit": true,
    "noUncheckedSideEffectImports": true,
    "stableTypeOrdering": true,
    "exactOptionalPropertyTypes": true,
    "noUncheckedIndexedAccess": true,
    "skipLibCheck": false,
    "rootDir": ".",
    "types": []
  },
  "include": [
    "test-cases/basic/src/**/*.ts",
    "test-cases/generated/src/**/*.ts"
  ]
}
