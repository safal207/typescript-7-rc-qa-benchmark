{
  "name": "typescript-7-rc-qa-benchmark",
  "version": "0.3.0",
  "private": true,
  "description": "Independent QA benchmark comparing TypeScript 6.0 and TypeScript 7.0 RC.",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "versions": "node scripts/versions.mjs",
    "generate:synthetic": "node scripts/generate-project.mjs",
    "generate:real-world": "node scripts/generate-real-world-type-fest.mjs",
    "generate": "npm run generate:synthetic && npm run generate:real-world",
    "typecheck:ts6": "tsc6 -p tsconfig.json --noEmit --pretty false",
    "typecheck:ts7": "tsc -p tsconfig.json --noEmit --pretty false",
    "typecheck:heavy:ts6": "tsc6 -p tsconfig.type-heavy.json --noEmit --pretty false",
    "typecheck:heavy:ts7": "tsc -p tsconfig.type-heavy.json --noEmit --pretty false",
    "typecheck:real-world:ts6": "tsc6 -p tsconfig.real-world-type-fest.json --noEmit --pretty false",
    "typecheck:real-world:ts7": "tsc -p tsconfig.real-world-type-fest.json --noEmit --pretty false",
    "compare:diagnostics": "node scripts/compare-diagnostics.mjs",
    "collect:extended-diagnostics": "node scripts/collect-extended-diagnostics.mjs",
    "benchmark": "node scripts/benchmark.mjs",
    "benchmark:checkers": "node scripts/benchmark-checker-scaling.mjs",
    "benchmark:real-world": "node scripts/benchmark-real-world-type-fest.mjs",
    "verify:outputs": "node scripts/verify-outputs.mjs",
    "qa": "npm run generate && npm run versions && npm run typecheck:ts6 && npm run typecheck:ts7 && npm run typecheck:heavy:ts6 && npm run typecheck:heavy:ts7 && npm run typecheck:real-world:ts6 && npm run typecheck:real-world:ts7 && npm run compare:diagnostics && npm run collect:extended-diagnostics && npm run benchmark && npm run benchmark:real-world && npm run verify:outputs"
  },
  "devDependencies": {
    "@typescript/typescript6": "^6.0.0",
    "type-fest": "5.7.0",
    "typescript": "rc"
  }
}
